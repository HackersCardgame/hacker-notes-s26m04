HEADERS = {"User-Agent": "Mozilla/5.0"}

def log_tracking(tracking_number):
    response = requests.get(TRACKING_URL.format(tracking_number), headers=HEADERS)
    data = response.json()

    # Speichere Rohdaten mit Zeitstempel
    timestamp = datetime.now().isoformat()
    filename = f"post_tracking_{timestamp}.json"
